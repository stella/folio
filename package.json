{
  "name": "@stll/folio-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "folio monorepo: @stll/folio-core (headless .docx engine) + @stll/folio-react (React editor).",
  "homepage": "https://github.com/stella/folio",
  "bugs": {
    "url": "https://github.com/stella/folio/issues"
  },
  "license": "Apache-2.0",
  "author": "STLL",
  "repository": {
    "type": "git",
    "url": "https://github.com/stella/folio.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "clean": "git clean -xdf packages/*/dist .cache .turbo node_modules",
    "build": "bun --filter '@stll/folio-core' build && bun --filter '@stll/folio-react' build",
    "build:core": "bun --filter '@stll/folio-core' build",
    "build:react": "bun --filter '@stll/folio-react' build",
    "typecheck": "bun --filter '*' typecheck",
    "test": "bun --filter '*' test",
    "lint": "bun --bun oxlint -c oxlint.config.ts packages scripts test",
    "lint:fix": "bun --bun oxlint -c oxlint.config.ts --fix packages scripts test",
    "format": "oxfmt .",
    "validate-dist": "bun scripts/validate-dist.ts core && bun scripts/validate-dist.ts react",
    "validate-dist:core": "bun scripts/validate-dist.ts core",
    "validate-dist:react": "bun scripts/validate-dist.ts react",
    "test:visual": "bunx playwright test",
    "test:interactions": "bunx playwright test --project=interactions",
    "test:visual:update": "bunx playwright test --update-snapshots",
    "test:visual:report": "bunx playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@stll/oxlint-config": "0.3.0",
    "@types/bun": "1.3.14",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260624.1",
    "better-result": "2.9.2",
    "fast-check": "^4.8.0",
    "lightningcss": "1.32.0",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "oxlint-tsgolint": "^0.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsdown": "0.22.3",
    "typescript": "6.0.3",
    "use-intl": "^4.13.0"
  },
  "packageManager": "bun@1.3.14"
}
