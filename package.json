{
  "name": "@stll/folio-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "folio monorepo: framework-neutral DOCX engine, React/Vue editors, Nuxt module, and agent tooling.",
  "homepage": "https://github.com/stella/folio",
  "bugs": {
    "url": "https://github.com/stella/folio/issues"
  },
  "license": "Apache-2.0",
  "author": "STLL",
  "repository": {
    "type": "git",
    "url": "https://github.com/stella/folio.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "clean": "git clean -xdf packages/*/dist .cache .turbo node_modules",
    "check:parity-contract": "node scripts/check-parity-contract.mjs",
    "check:export-parity": "node scripts/check-export-parity.mjs",
    "test:e2e:vue": "bunx playwright test --project=vue",
    "test:e2e:parity": "bunx playwright test --project=parity",
    "build": "bun --filter '@stll/folio-core' build && bun --filter '@stll/folio-react' build && bun --filter '@stll/folio-agents' build && bun --filter '@stll/folio-vue' build && bun --filter '@stll/folio-nuxt' build",
    "build:core": "bun --filter '@stll/folio-core' build",
    "build:react": "bun --filter '@stll/folio-react' build",
    "typecheck": "bun --filter '*' typecheck",
    "test": "bun --filter '*' test && bun test scripts",
    "test:property": "bun --filter '*' test:property",
    "typegen": "bun scripts/i18n-typegen.ts packages/core/src/i18n/messages",
    "check:i18n": "bun scripts/i18n-typegen.ts packages/core/src/i18n/messages --check && bun scripts/i18n-check.ts packages/core/src/i18n/messages",
    "codemod:eigenpal": "bun scripts/migrate-eigenpal.ts",
    "lint": "bun --bun oxlint -c oxlint.config.ts packages scripts test benchmarks parity",
    "lint:fix": "bun --bun oxlint -c oxlint.config.ts --fix packages scripts test benchmarks parity",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "sync-ai": "bash scripts/sync-ai-skills.sh",
    "test:packaged-consumer": "bun scripts/packaged-consumer-build.ts",
    "test:packaged-consumer-smoke": "bun scripts/packaged-consumer-smoke.ts",
    "validate-dist": "bun scripts/validate-dist.ts core && bun scripts/validate-dist.ts react && bun scripts/validate-dist.ts agents && bun scripts/validate-dist.ts vue",
    "validate-dist:core": "bun scripts/validate-dist.ts core",
    "validate-dist:react": "bun scripts/validate-dist.ts react",
    "validate-dist:agents": "bun scripts/validate-dist.ts agents",
    "validate-dist:vue": "bun scripts/validate-dist.ts vue",
    "api:update": "bun scripts/api-reports.ts --update",
    "api:check": "bun scripts/api-reports.ts",
    "changeset:version": "changeset version && bun install",
    "changeset:check": "bun scripts/check-changeset.ts",
    "bench": "bun benchmarks/index.ts",
    "bench:cross-language": "bun benchmarks/cross-language/run.ts",
    "parity": "bun parity/cli.ts",
    "test:visual": "bunx playwright test",
    "test:interactions": "bunx playwright test --project=interactions",
    "test:differential": "cd packages/core && bun test src/docx/__tests__/differential.test.ts",
    "test:visual:update": "bunx playwright test --update-snapshots",
    "test:visual:report": "bunx playwright show-report"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@codspeed/tinybench-plugin": "^5.7.1",
    "@eigenpal/docx-editor-core": "^1.9.0",
    "@microsoft/api-extractor": "7.58.9",
    "@playwright/test": "^1.61.1",
    "@stll/folio-core": "workspace:*",
    "@stll/oxlint-config": "0.3.0",
    "@types/bun": "1.3.14",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript/native": "npm:typescript@7.0.2",
    "better-result": "2.9.2",
    "fast-check": "^4.9.0",
    "jszip": "3.10.1",
    "lightningcss": "1.32.0",
    "mammoth": "^1.12.0",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "oxlint-tsgolint": "^0.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tinybench": "^6.0.2",
    "tsdown": "0.22.3",
    "typescript": "6.0.3",
    "use-intl": "^4.13.2"
  },
  "packageManager": "bun@1.3.14",
  "overrides": {
    "prosemirror-model": "1.25.10",
    "prosemirror-view": "1.42.0"
  },
  "dependencies": {
    "vue-tsc": "^3.3.7"
  }
}
