{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/stella/folio/specifications/evidence/schema.json",
  "title": "Folio behavior evidence record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "claimType",
    "claim",
    "profiles",
    "scope",
    "confidence",
    "sources",
    "fixtures"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "claimType": {
      "enum": [
        "application-behavior",
        "compatibility-exception",
        "prose-requirement",
        "schema-requirement"
      ]
    },
    "claim": { "type": "string", "minLength": 1 },
    "profiles": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "enum": ["opc", "strict", "transitional"] }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["feature", "applications"],
      "properties": {
        "feature": { "type": "string", "minLength": 1 },
        "applications": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "versions"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "versions": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      }
    },
    "confidence": { "enum": ["confirmed", "provisional", "reported"] },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sourceId", "locator"],
        "properties": {
          "sourceId": { "type": "string", "minLength": 1 },
          "locator": { "type": "string", "minLength": 1 }
        }
      }
    },
    "fixtures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "assertion"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "assertion": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
