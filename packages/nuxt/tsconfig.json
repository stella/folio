{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "declaration": true,
    "declarationMap": true,
    "paths": {
      "@stll/folio-vue": ["../vue/src/index.ts"],
      "@stll/folio-vue/composables": ["../vue/src/composables/index.ts"],
      "@stll/folio-core": ["../core/src/core.ts"],
      "@stll/folio-core/*": ["../core/src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
