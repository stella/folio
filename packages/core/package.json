{
  "name": "@stll/folio-core",
  "version": "0.4.0",
  "description": "Headless, framework-neutral core of folio: the OOXML (.docx) parser, document model, ProseMirror integration, and page-layout engine. No React.",
  "keywords": [
    "document-model",
    "docx",
    "headless",
    "ooxml",
    "pagination",
    "prosemirror",
    "word"
  ],
  "homepage": "https://github.com/stella/folio",
  "bugs": {
    "url": "https://github.com/stella/folio/issues"
  },
  "license": "Apache-2.0",
  "author": "STLL",
  "repository": {
    "type": "git",
    "url": "https://github.com/stella/folio.git",
    "directory": "packages/core"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./markdown": "./src/markdown/index.ts",
    "./server": "./src/server.ts",
    "./ai-edits": "./src/ai-edits/index.ts",
    "./content-controls": "./src/content-controls/index.ts",
    "./compat/eigenpal": "./src/compat/eigenpal.ts",
    "./watermark": "./src/watermark/index.ts",
    "./layout-engine": "./src/layout-engine/index.ts",
    "./layout-painter": "./src/layout-painter/index.ts",
    "./layout-bridge/engine/measuring": "./src/layout-bridge/engine/measuring/index.ts",
    "./prosemirror": "./src/prosemirror/index.ts",
    "./prosemirror/attrs": "./src/prosemirror/attrs/index.ts",
    "./prosemirror/conversion": "./src/prosemirror/conversion/index.ts",
    "./prosemirror/extensions": "./src/prosemirror/extensions/index.ts",
    "./prosemirror/schema": "./src/prosemirror/schema/index.ts",
    "./docx": "./src/docx/index.ts",
    "./*": "./src/*.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist && tsdown",
    "prepack": "bun run build",
    "pack:dry-run": "bun pm pack --dry-run",
    "typecheck": "bun ../../scripts/tsc-native.ts --noEmit -p tsconfig.build.json",
    "test": "bun test src",
    "test:property": "bun test $(grep -rlF 'fc.assert' src --include='*.test.ts')",
    "perf": "bun scripts/profile-editor.ts"
  },
  "dependencies": {
    "@stll/docx-core": "^0.1.0",
    "@stll/docx-utils": "^0.1.0",
    "@stll/template-conditions": "^0.1.0",
    "better-result": "2.9.2",
    "csstype": "^3.1.3",
    "fast-xml-parser": "^5.9.3",
    "jszip": "3.10.1",
    "marked": "^18.0.5",
    "prosemirror-commands": "^1.7.1",
    "prosemirror-dropcursor": "^1.8.2",
    "prosemirror-gapcursor": "^1.4.1",
    "prosemirror-history": "^1.5.0",
    "prosemirror-keymap": "^1.2.3",
    "prosemirror-model": "^1.25.9",
    "prosemirror-state": "^1.4.4",
    "prosemirror-tables": "^1.8.5",
    "prosemirror-transform": "^1.12.0",
    "prosemirror-view": "^1.41.8",
    "utif2": "^4.1.0",
    "valibot": "1.4.1",
    "y-prosemirror": "^1.3.7",
    "yjs": "^13.6.31"
  }
}
