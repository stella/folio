{
  "name": "@stll/folio-react",
  "version": "0.5.0",
  "description": "React editor for folio: a Word-document (.docx) editor for the browser, built on @stll/folio-core and ProseMirror.",
  "keywords": [
    "document-editor",
    "docx",
    "editor",
    "ooxml",
    "prosemirror",
    "react",
    "word",
    "wysiwyg"
  ],
  "homepage": "https://github.com/stella/folio",
  "bugs": {
    "url": "https://github.com/stella/folio/issues"
  },
  "license": "Apache-2.0",
  "author": "STLL",
  "repository": {
    "type": "git",
    "url": "https://github.com/stella/folio.git",
    "directory": "packages/react"
  },
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./compat/eigenpal": "./src/compat/eigenpal.tsx",
    "./messages": "./src/i18n/messages.ts",
    "./editor.css": "./src/styles/editor.css",
    "./standalone.css": "./src/styles/standalone.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist && tsdown && bun scripts/build-css.ts",
    "build:css": "bun scripts/build-css.ts",
    "prepack": "bun run build",
    "pack:dry-run": "bun pm pack --dry-run",
    "typecheck": "tsgo --noEmit -p tsconfig.build.json",
    "test": "bun test src"
  },
  "dependencies": {
    "@base-ui/react": "1.6.0",
    "@fontsource/arimo": "^5.2.8",
    "@fontsource/caladea": "^5.2.8",
    "@fontsource/carlito": "^5.2.8",
    "@fontsource/cousine": "^5.2.7",
    "@fontsource/noto-sans-arabic": "^5.2.7",
    "@fontsource/tinos": "^5.2.7",
    "@stll/folio-core": "workspace:^",
    "better-result": "2.9.2",
    "lucide-react": "1.21.0",
    "prosemirror-history": "^1.5.0",
    "prosemirror-model": "^1.25.9",
    "prosemirror-state": "^1.4.4",
    "prosemirror-tables": "^1.8.5",
    "prosemirror-view": "^1.41.8",
    "yjs": "^13.6.31"
  },
  "devDependencies": {
    "@tailwindcss/cli": "4.3.1",
    "tailwindcss": "4.3.1",
    "y-prosemirror": "^1.3.7"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "use-intl": ">=4.0.0"
  }
}
